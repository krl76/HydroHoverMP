{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "a930a1e4187541c89e801ef5e6c52251",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GerstnerWaveCalc (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 915.0,
            "y": -3.0,
            "width": 260.0,
            "height": 173.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "3410de9f23cd4e26a8323a9879ab5b6c"
        },
        {
            "m_Id": "65efd12741f1411d86abbda8df00ea8d"
        },
        {
            "m_Id": "5cd87861f2324404b14dd61b94c12caa"
        },
        {
            "m_Id": "831ba8b1e2a64b22b2507f2cf4d5a382"
        },
        {
            "m_Id": "6d38eead615a43ce9fc33f9ed32c7cc5"
        },
        {
            "m_Id": "fe9eb1ff9dab415f9720d7f985c55d40"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GerstnerWaveCalc",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float len = max(WaveParams.x, 0.01); // Защита от деления на 0\r\nfloat amp = WaveParams.y;\r\nfloat speed = WaveParams.z;\r\n\r\nfloat k = 6.28318 / len; \r\nfloat f = k * (dot(WaveDir, WorldPos.xz) - speed * Time);\r\n\r\nOutOffset = TotalOffset + amp * sin(f);"
}

